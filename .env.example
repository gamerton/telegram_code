# Get your bot token from @BotFather on Telegram
BOT_TOKEN=123456:ABC-DEF...

# Your Telegram user ID — get it from @userinfobot
AUTHORIZED_USER_ID=987654321

# Optional: command timeout in seconds (default: 300)
# COMMAND_TIMEOUT=300

# Optional: how often to update the Telegram message with new output, in seconds (default: 2.0)
# OUTPUT_UPDATE_INTERVAL=2.0

# Optional: shell executable (default: /bin/bash)
# SHELL_EXECUTABLE=/bin/bash
